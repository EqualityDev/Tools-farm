{
    "typingIndicator": true,
    "silentTextMessages": false,
    "offlineStatus": false,
    "batteryCheck": {
        "enabled": false,
        "minPercentage": 20,
        "refreshInterval": 60
    },
    "captcha": {
        "openCaptchaWebsite": true,
        "stopCodeIfFailedToSolve": true,
        "notifications": {
            "enabled": true,
            "captchaContent": "Captcha detected for {username} in {channelname} ({captchatype})",
            "bannedContent": "Ban detected for {username} in {channelname} ({captchatype})",
            "reccur": {
                "enabled": false,
                "times_to_reccur": 3
            }
        },
        "playAudio": {
            "enabled": false,
            "path": "Beep.mp3"
        },
        "toastOrPopup": {
            "enabled": false,
            "captchaContent": "{username} captcha in {channelname}",
            "bannedContent": "{username} banned in {channelname}",
            "termuxToast": {
                "textColour": "white",
                "backgroundColour": "black",
                "position": "top"
            }
        },
        "termux": {
            "vibrate": {
                "enabled": false,
                "time": 2
            },
