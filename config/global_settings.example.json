        "webhookUserIdToPingOnCaptcha": null,
        "animal_log": {
            "enabled": false,
            "rank": {
                "common": false,
                "uncommon": false,
                "rare": false,
                "epic": false,
                "mythical": false,
                "legendary": false,
                "fabled": false,
                "hidden": false,
                "gem": false
            }
        },
